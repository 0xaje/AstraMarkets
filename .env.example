# AstraMarkets — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real API keys.
# NEVER commit your .env file to git.

# ─── Somnia L1 Blockchain (Required) ─────────────────────────────
# Somnia RPC Endpoint (Default: Somnia Shannon Testnet Dream RPC)
SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# Deployed MarketFactory contract address on Somnia L1
MARKET_FACTORY_ADDRESS=0xyour_deployed_market_factory_address_here

# Private key of the connection wallet (DO NOT SHARE OR HARDCODE)
# Used to pay gas for contract deployment and on-chain prediction creation
SOMNIA_PRIVATE_KEY=0xyour_private_key_here

# ─── OpenAI (Agent Decision Engine - Required for LLM) ───────────
# Required for autonomous agent LLM calls (MacroAgent, SocialAgent, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Model used by agents (default: gpt-4o-mini for cost efficiency)
# Options: gpt-4o-mini | gpt-4o | gpt-4-turbo
AGENT_LLM_MODEL=gpt-4o-mini

# Agent cycle interval in ms (default: 15000 = 15 seconds)
AGENT_CYCLE_MS=15000

# ─── NewsAPI (Optional) ───────────────────────────────────────────
# Get your free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ─── Reddit API (Optional - client credentials) ──────────────────
# Create an app at: https://www.reddit.com/prefs/apps
# Choose "script" type. Use "http://localhost" as redirect URI.
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_SECRET=your_reddit_client_secret_here

# ─── SerpAPI (Google Trends - Optional) ──────────────────────────
# Get your key at: https://serpapi.com/
# Uses the google_trends_trending_now engine
SERP_API_KEY=your_serpapi_key_here

# ─── Signal Server Port ───────────────────────────────────────────
SIGNAL_PORT=4000
