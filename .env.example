# AstraMarkets — Environment Setup Guide
# ─────────────────────────────────────────────────────────────────
# ⚠️ Do NOT commit the .env file to your repository.
# Copy this file to .env and insert your real API keys before starting.

# ─── 1. BLOCKCHAIN CONFIGURATION (Required) ──────────────────────
# Somnia RPC Endpoint (Default: Somnia Testnet Dream RPC)
# Fallback: https://somnia-testnet.socialscan.io
SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# Deployed MarketFactory contract address on Somnia L1
MARKET_FACTORY_ADDRESS=0x22e9725a264B91BEfE084D0D3F66B5E13C25d07a

# Private key of the Broadcaster Wallet (DO NOT SHARE)
# Required to pay gas for executing autonomous market creations.
SOMNIA_PRIVATE_KEY=your_private_key_here

# ─── 2. AI PROVIDERS (Required) ──────────────────────────────────
# Required for autonomous agent LLM calls (MacroAgent, SocialAgent, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Model used by agents (default: gpt-4o-mini for speed/cost efficiency)
AGENT_LLM_MODEL=gpt-4o-mini

# ─── 3. SIGNAL INGESTION API (Optional but recommended) ──────────
# Free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Create an app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_SECRET=your_reddit_client_secret_here

# Google Trends data via SerpAPI (Free key at: https://serpapi.com/)
SERP_API_KEY=your_serpapi_key_here

# ─── 4. DATABASE CONFIGURATION (Required) ────────────────────────
# SQLite Database path for Agent Memory & Intelligence Scores
DATABASE_PATH=./astra_swarm_v2.db

# ─── 5. MONITORING & SYSTEM CONTROL ──────────────────────────────
# Backend Signal & API Server Port
SIGNAL_PORT=4000

# Agent evaluation cycle interval in ms (default: 15000 = 15s)
AGENT_CYCLE_MS=15000

# ─── 6. FRONTEND CONFIGURATION ───────────────────────────────────
# Node env mode ('development' or 'production')
NODE_ENV=production
